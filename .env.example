# ─── Discord ───
# Create an Application at https://discord.com/developers/applications
# Then go to the Bot tab to issue a token. Enable the GUILD VOICE STATES intent.
DISCORD_BOT_TOKEN=

# Numeric IDs of the server and voice channel the bot should join.
# Enable Developer Mode in your Discord client, then right-click → "Copy ID".
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=

# ─── VE-PG4 RoIP Gateway ───
# Defaults match the RoIP Gateway 1 web UI defaults. Override only if your unit
# is configured differently.
BRIDGE_MCAST_GROUP=239.255.255.1
BRIDGE_RTP_PORT=22510
BRIDGE_RTCP_PORT=22511
BRIDGE_MCAST_TTL=32

# When the host has multiple NICs, pin the IP that is on the same LAN as VE-PG4.
# BRIDGE_MCAST_IFACE_IP=192.168.X.Y

# ─── This bot's RTP/RTCP identity ───
BRIDGE_SSRC=0xCAFEBABE
BRIDGE_RTCP_CNAME=239.255.255.1
BRIDGE_RTCP_INTERVAL_S=5

# ─── PTT policy ───
# Auto-release the gate after this many ms of silence. 800 ms keeps short pauses
# between words from flapping the gate.
BRIDGE_PTT_IDLE_RELEASE_MS=800

# Multi-speaker policy for Discord → Radio direction.
#   fcfs (default): only the first speaker is forwarded to the radio while the
#                   gate is held; later speakers are dropped.
#   mix:            all simultaneous speakers are sum-mixed (with clipping
#                   protection) into one RTP stream. Useful when several Discord
#                   users may transmit at once and the radio should hear them
#                   together.
BRIDGE_DISCORD_MIX_MODE=fcfs

# Discord receive (RX) toggle. Set to "0" / "false" to run TX-only — radio
# audio still reaches Discord, but Discord users cannot talk back to the radio.
# Useful as a workaround when upstream voice-recv breaks against new Discord
# voice protocol versions.
BRIDGE_DISCORD_RX_ENABLED=1
